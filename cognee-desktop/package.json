{
  "name": "cognee-desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "vite build && electrobun dev --watch",
    "dev:debug": "COGNEE_DEBUG=1 vite build && COGNEE_DEBUG=1 electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "storybook": "storybook dev -p 6006 --no-open",
    "prepare": "cd .. && lefthook install"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "electrobun": "~1.18.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-force-graph-3d": "^1.29.1",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.33",
    "@types/bun": "~1.3.13",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "knip": "6.12.0",
    "lefthook": "^2.1.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "ultracite": "7.6.3",
    "vite": "^8.0.10"
  }
}
